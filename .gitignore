# Build directories (covers build/, build-android-arm64/, build-android/, etc.)
build*/

# VS Code settings (optional - you can track these if you want)
.vscode/

# KDevelop files
.kdev4/
*.kdev4
.kdevelop

# Machine-specific CMake preset overrides (paths to local Qt/SDK installs)
CMakeUserPresets.json

# Keystores — never commit these
*.jks
*.keystore

# Compiled binaries and Android outputs
*.o
*.out
*.so
*.a
*.apk
*.aab
*.aar
*.idsig
tictactoe
InfiniTTT_CLI
InfiniTTT_GUI

# CMake
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
compile_commands.json

# Debian packaging build artifacts
obj-x86_64-linux-gnu/
debian/infinittt/
debian/.debhelper/
debian/files
debian/*.log
debian/*.substvars
debian/*-stamp

# Generated packages (in parent directory)
../*.deb
../*.ddeb
../*.buildinfo
../*.changes
../*.dsc
../*.tar.*