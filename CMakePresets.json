{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 16, "patch": 0 },
  "configurePresets": [
    {
      "name": "desktop-debug",
      "displayName": "Desktop (Debug)",
      "description": "Build for the current desktop platform",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "desktop-release",
      "displayName": "Desktop (Release)",
      "description": "Build for the current desktop platform",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "android-arm64",
      "displayName": "Android arm64-v8a (Release)",
      "description": "Requires QTDIR, ANDROID_SDK_ROOT, and ANDROID_NDK_ROOT env vars",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-android-arm64",
      "toolchainFile": "$env{QTDIR}/lib/cmake/Qt6/qt.toolchain.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "ANDROID_ABI": "arm64-v8a",
        "ANDROID_PLATFORM": "android-26",
        "ANDROID_SDK_ROOT": "$env{ANDROID_SDK_ROOT}",
        "ANDROID_NDK_ROOT": "$env{ANDROID_NDK_ROOT}"
      }
    },
    {
      "name": "android-arm",
      "displayName": "Android armv7 (Release)",
      "description": "Requires QTDIR_ARM, ANDROID_SDK_ROOT, and ANDROID_NDK_ROOT env vars",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-android-arm",
      "toolchainFile": "$env{QTDIR_ARM}/lib/cmake/Qt6/qt.toolchain.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "ANDROID_ABI": "armeabi-v7a",
        "ANDROID_PLATFORM": "android-26",
        "ANDROID_SDK_ROOT": "$env{ANDROID_SDK_ROOT}",
        "ANDROID_NDK_ROOT": "$env{ANDROID_NDK_ROOT}"
      }
    },
    {
      "name": "android-x86_64",
      "displayName": "Android x86_64 (Release) — for emulator testing",
      "description": "Requires QTDIR_X86_64, ANDROID_SDK_ROOT, and ANDROID_NDK_ROOT env vars",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-android-x86_64",
      "toolchainFile": "$env{QTDIR_X86_64}/lib/cmake/Qt6/qt.toolchain.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "ANDROID_ABI": "x86_64",
        "ANDROID_PLATFORM": "android-26",
        "ANDROID_SDK_ROOT": "$env{ANDROID_SDK_ROOT}",
        "ANDROID_NDK_ROOT": "$env{ANDROID_NDK_ROOT}"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "desktop-debug",
      "configurePreset": "desktop-debug",
      "targets": ["InfiniTTT_QML", "InfiniTTT_CLI"]
    },
    {
      "name": "desktop-release",
      "configurePreset": "desktop-release",
      "targets": ["InfiniTTT_QML", "InfiniTTT_CLI"]
    },
    {
      "name": "android-arm64",
      "configurePreset": "android-arm64",
      "targets": ["InfiniTTT_QML_make_apk"]
    },
    {
      "name": "android-arm",
      "configurePreset": "android-arm",
      "targets": ["InfiniTTT_QML_make_apk"]
    },
    {
      "name": "android-x86_64",
      "configurePreset": "android-x86_64",
      "targets": ["InfiniTTT_QML_make_apk"]
    }
  ]
}
